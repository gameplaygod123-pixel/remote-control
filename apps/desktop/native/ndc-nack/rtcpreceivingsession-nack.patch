+// PATCH (Personal Remote): build + send a Generic NACK (RTPFB PT=205 FMT=1) listing
+// the missing sequence numbers, so the peer's RtcpNackResponder retransmits them.
+// Mirrors pushPLI; addMissingPacket compresses runs into PID+BLP FCI parts.
+void RtcpReceivingSession::pushNACK(const message_callback &send,
+                                    const std::vector<uint16_t> &missingSeqs) {
+	if (missingSeqs.empty())
+		return;
+	// Worst case = one FCI part per missing packet; trim to the real count after packing.
+	auto message = make_message(RtcpNack::Size(missingSeqs.size()), Message::Control);
+	auto *nack = reinterpret_cast<RtcpNack *>(message->data());
+	unsigned int fciCount = 0;
+	uint16_t fciPID = 0;
+	for (uint16_t seq : missingSeqs)
+		nack->addMissingPacket(&fciCount, &fciPID, seq);
+	nack->preparePacket(mSsrc, fciCount);
+	message->resize(RtcpNack::Size(fciCount));
+	send(message);
+}
